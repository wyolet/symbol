{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT}/.. symbol hook"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT}/.. symbol hook"
          }
        ]
      }
    ]
  }
}
